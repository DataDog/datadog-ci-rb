module Datadog
  module CI
    module Contrib
      module Minitest
        module Test
          @_dd_original_minitest_run: untyped

          def self._dd_original_minitest_run: () -> untyped

          def self._dd_original_minitest_run=: (untyped) -> untyped

          module ClassMethods
            @datadog_itr_unskippable_suite: bool
            @datadog_itr_unskippable_tests: Array[String]?

            def datadog_itr_unskippable: (*untyped) -> void

            def dd_suite_unskippable?: () -> bool

            def dd_test_unskippable?: (String test_name) -> bool
          end

          module InstanceMethods : ::Minitest::Test
            include ::Minitest::Test::LifecycleHooks
            extend ClassMethods

            def run: () -> ::Minitest::Result

            def after_teardown: () -> untyped

            private

            def start_datadog_test: () -> Datadog::CI::Test?

            def skip_datadog_test: (Datadog::CI::Test test_span) -> ::Minitest::Result

            def datadog_integration: () -> Datadog::CI::Contrib::Integration

            def datadog_configuration: () -> untyped

            def _dd_test_tracing_component: () -> Datadog::CI::TestTracing::Component

            def finish_with_result: (Datadog::CI::Span? span, String result_code) -> void
          end
        end
      end
    end
  end
end
