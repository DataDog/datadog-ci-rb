module Datadog
  module CI
    module TestRetries
      module Driver
        class RetryFlakyFixed < Base
          @attempts: Integer

          @max_attempts: Integer

          @failed_once: bool

          def initialize: (Datadog::CI::Test test_span, max_attempts: Integer) -> void

          def should_retry?: () -> bool

          def record_retry: (Datadog::CI::Test test_span) -> void

          def retry_reason: () -> String
        end
      end
    end
  end
end
